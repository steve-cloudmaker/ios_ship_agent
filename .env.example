# iOS Ship Agent — Environment Variables
# Copy this file to .env and fill in your keys
# cp .env.example .env

# ============================================================
# REQUIRED
# ============================================================

# Anthropic API key (for Claude — idea, keyword scoring, metadata)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (for DALL-E 3 — app icon generation)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ============================================================
# OPTIONAL — App Build
# ============================================================

# Skip the Claude Code build step (for testing visuals/metadata only)
SKIP_BUILD=false

# Dry run mode — no real API calls, uses placeholders
DRY_RUN=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================
# OPTIONAL — ASO Provider
# ============================================================

# ASO data source: scraper (default) | astro | appfollow | apptweak
ASO_PROVIDER=scraper

# Astro ASO API key (set ASO_PROVIDER=astro to use)
# ASTRO_API_KEY=

# AppFollow API key (set ASO_PROVIDER=appfollow to use)
# APPFOLLOW_API_KEY=

# ============================================================
# OPTIONAL — App Store Connect (auto-submission)
# ============================================================
# These are only used when AUTO_SUBMIT=true
# Leave blank for the default "submission-ready package" mode

AUTO_SUBMIT=false

# APP_STORE_CONNECT_KEY_ID=XXXXXXXXXX
# APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APP_STORE_CONNECT_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8

# ============================================================
# OPTIONAL — Output
# ============================================================

# Where to write submission packages
OUTPUT_DIR=output

# Log file path (leave blank to log to console only)
# LOG_FILE=logs/ios_ship_agent.log
